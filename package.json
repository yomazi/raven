{
  "name": "raven",
  "version": "1.0.0",
  "description": "A sanity-inducing tool for Google Workspaces.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "migrate": "npm run migrate --prefix server",
    "migrate:list": "npm run migrate:list --prefix server",
    "migrate:dry": "npm run migrate:dry --prefix server",
    "migrate:down": "npm run migrate:down --prefix server",
    "migrate:new": "npm run migrate:new --prefix server",
    "dev": "npm run dev:server",
    "dev:server": "npm --prefix server run dev",
    "start": "npm run start:server",
    "start:server": "npm --prefix server run start",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
